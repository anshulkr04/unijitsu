# Kraftfile for test-agent unikernel
#
# This builds a minimal HTTP server unikernel targeting Xen x86_64.
# It includes the lwIP network stack and POSIX compatibility layer.

spec: v0.6

unikraft:
  version: stable
  kconfig:
    # Core
    CONFIG_LIBUKBOOT: 'y'
    CONFIG_LIBNOLIBC: 'y'
    CONFIG_LIBPOSIX_SOCKET: 'y'
    CONFIG_LIBPOSIX_PROCESS: 'y'
    CONFIG_LIBPOSIX_USER: 'y'
    CONFIG_LIBPOSIX_SYSINFO: 'y'
    CONFIG_LIBPOSIX_FDTAB: 'y'

    # Network device abstraction layer
    CONFIG_LIBUKNETDEV: 'y'
    CONFIG_LIBUKNETDEV_EINFO_LIBPARAM: 'y'

    # Xen netfront driver
    CONFIG_XEN_NETFRONT: 'y'

    # Memory allocators
    CONFIG_LIBUKALLOC: 'y'
    CONFIG_LIBUKALLOCBBUDDY: 'y'
    CONFIG_LIBUKFALLOCBUDDY: 'y'

    # Cooperative scheduler (preemptive key not recognized in 0.20)
    CONFIG_LIBUKSCHED: 'y'
    CONFIG_LIBUKSCHEDCOOP: 'y'

    # Time
    CONFIG_LIBPOSIX_TIME: 'y'

# lwIP MUST be declared here as an external library — kconfig CONFIG_LIBLWIP
# alone does NOT cause kraft to fetch/build it. Without this section,
# no liblwip directory appears in the build and AF_INET is never registered.
libraries:
  lwip:
    source: https://github.com/unikraft/lib-lwip.git
    version: stable
    kconfig:
      CONFIG_LWIP_UKNETDEV: 'y'
      CONFIG_LWIP_AUTOIFACE: 'y'
      CONFIG_LWIP_SOCKET: 'y'
      CONFIG_LWIP_THREADS: 'y'
      CONFIG_LWIP_HEAP: 'y'
      CONFIG_LWIP_IPV4: 'y'
      CONFIG_LWIP_TCP: 'y'
      CONFIG_LWIP_UDP: 'y'
      CONFIG_LWIP_ARP: 'y'
      CONFIG_LWIP_ICMP: 'y'
      CONFIG_LWIP_DHCP: 'n'
      CONFIG_LWIP_DNS: 'n'

targets:
  - platform: xen
    architecture: x86_64
