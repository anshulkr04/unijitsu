# Kraftfile for test-agent unikernel
#
# This builds a minimal HTTP server unikernel targeting Xen x86_64.
# It includes the lwIP network stack and POSIX compatibility layer.

spec: v0.6

unikraft:
  version: stable
  kconfig:
    # Core
    CONFIG_LIBUKBOOT: 'y'
    CONFIG_LIBNOLIBC: 'y'
    CONFIG_LIBPOSIX_SOCKET: 'y'
    CONFIG_LIBPOSIX_PROCESS: 'y'
    CONFIG_LIBPOSIX_USER: 'y'
    CONFIG_LIBPOSIX_SYSINFO: 'y'

    # File descriptor table — required by posix-socket in Unikraft 0.20
    # Unikraft 0.20 uses posix-fdtab, NOT vfscore, as the socket fd backing store
    # Without this, socket() returns -1 (ENOSYS) on every call
    CONFIG_LIBPOSIX_FDTAB: 'y'

    # Network device abstraction layer + polling (uknetdev polls netfront for packets)
    CONFIG_LIBUKNETDEV: 'y'
    CONFIG_LIBUKNETDEV_DISPATCHERTHREADS: 'y'

    # Network stack (lwIP) — static IP only, no DHCP
    CONFIG_LIBLWIP: 'y'
    CONFIG_LWIP_SOCKET: 'y'
    CONFIG_LWIP_IPV4: 'y'
    CONFIG_LWIP_TCP: 'y'
    CONFIG_LWIP_UDP: 'y'
    CONFIG_LWIP_DHCP: 'n'
    CONFIG_LWIP_DNS: 'n'
    CONFIG_LWIP_ARP: 'y'

    # Xen-specific
    CONFIG_XEN_NETFRONT: 'y'

    # Network device config via cmdline (netdev.ip0=...)
    # UK_LIBPARAM_PARAM_ARR_ALIAS creates indexed params: netdev.ip0, netdev.ip1, ...
    CONFIG_LIBUKNETDEV_EINFO_LIBPARAM: 'y'

    # Memory
    CONFIG_LIBUKALLOC: 'y'
    CONFIG_LIBUKALLOCBBUDDY: 'y'
    CONFIG_LIBUKFALLOCBUDDY: 'y'

    # Scheduler
    CONFIG_LIBUKSCHED: 'y'
    CONFIG_LIBUKSCHEDCOOP: 'y'

    # Time (provides sleep/nanosleep for yielding)
    CONFIG_LIBPOSIX_TIME: 'y'

targets:
  - platform: xen
    architecture: x86_64
